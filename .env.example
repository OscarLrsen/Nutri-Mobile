# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real values there either way is fine
# for the Supabase publishable key (it's designed to be public/client-embeddable,
# protected by RLS — same key already shipped in Nutri-Frontend's NEXT_PUBLIC_
# build), but keep the habit of not committing .env.local regardless.

# Backend base URL (no trailing slash, and — unlike the web app's
# NEXT_PUBLIC_API_URL — WITHOUT the /api suffix). Mobile endpoint paths
# include an explicit /api/... prefix instead, because /health and the
# SignalR hub (/hubs/kitchen) live OUTSIDE /api on the backend.
# See lib/env.ts for the Expo Go / simulator / emulator localhost gotcha.
EXPO_PUBLIC_API_URL=http://localhost:5069

# Same Supabase project used by Nutri-Frontend (single project, no separate
# staging DB — confirmed during backend admin-user provisioning).
EXPO_PUBLIC_SUPABASE_URL=https://lkfjedrbdoxqsyrcznla.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_2m6fvBmfUH15BIxuEeUrWQ_u94K92lj
